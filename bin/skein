#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "skein"

case ARGV[0]
when "repl", nil
  Skein::Repl.new.run
when "kernel"
  Skein::Kernel.new.run
when "version", "-v", "--version"
  puts "Skein #{Skein::VERSION}"
else
  warn "Usage: skein [repl|kernel|version]"
  warn ""
  warn "Commands:"
  warn "  repl      Interactive CLI (default)"
  warn "  kernel    Telegram-backed daemon"
  warn "  version   Print version"
  exit 1
end
